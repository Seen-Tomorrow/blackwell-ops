  "ik-extreme": {
    "binary_name": "llama-server.exe",
    "description": "IK-Extreme Blackwell Flagship (Ikaurakow fork)",
    "params": [
      {
        "key": "IK-Performance",
        "label": "IK-Performance",
        "config_key": "ik_perf",
        "flag": null,
        "ptype": "logic_only",
        "values": ["ultra", "balanced"],
        "default": "ultra",
        "ui_group": "Performance",
        "note": "Ultra enables Hadamard Transforms, Async Scheduling, and Graph Reuse.",
        "sub_params": {
          "ultra": ["-sas", "1", "-gr", "1", "-khad", "1", "-vhad", "1", "-mla", "3"],
          "balanced": ["-sas", "0", "-gr", "1", "-khad", "0", "-vhad", "0", "-mla", "1"]
        }
      },
      {
        "key": "GPU-Sync",
        "label": "GPU-Sync",
        "config_key": "gpu_sync",
        "flag": "-smf16",
        "ptype": "arg_select",
        "values": ["1", "0"],
        "default": "1",
        "ui_group": "Multi-GPU",
        "note": "Split-Mode F16 (1) uses 16-bit for inter-GPU data exchange. Faster on dual RTX 6000s."
      },
      {
        "key": "Device",
        "label": "Device",
        "config_key": "device",
        "flag": null,
        "ptype": "arg_select",
        "values": ["GPU-0", "GPU-1"],
        "default": "GPU-0",
        "ui_group": "Core",
        "note": "Select which GPU to use for inference."
      },
      {
        "key": "Split",
        "label": "Split",
        "config_key": "split_mode",
        "flag": "--split-mode",
        "ptype": "arg_select",
        "values": ["none", "layer", "row"],
        "default": "none",
        "ui_group": "Multi-GPU",
        "note": "How to split model across multiple GPUs."
      },
      {
        "key": "RAM-Cache",
        "label": "RAM-Cache",
        "config_key": "cache_ram",
        "flag": "-cram",
        "ptype": "arg_select",
        "values": [4096, 8192, 16384, 32768],
        "default": 8192,
        "ui_group": "Performance",
        "note": "Dedicated MiB in system RAM for prompt caching. Speeds up repeat system prompts."
      },
      {
        "key": "Cache-Sim",
        "label": "Cache-Sim",
        "config_key": "cache_similarity",
        "flag": "-crs",
        "ptype": "arg_select",
        "values": ["0.50", "0.75", "0.90", "0.95"],
        "default": "0.90",
        "ui_group": "Performance",
        "note": "Min similarity to trigger RAM cache. 0.90 is strict/fast."
      },
      {
        "key": "uBatch",
        "label": "UBatch",
        "config_key": "ubatch",
        "flag": "-ub",
        "ptype": "arg_select",
        "values": [128, 256, 512, 1024],
        "default": 512,
        "ui_group": "Performance",
        "note": "Micro-batch size. IK-llama prefers 512 for Blackwell."
      },
      {
        "key": "KV-Quant",
        "label": "KV-Quant",
        "config_key": "kv_quant",
        "flag": "-ctk",
        "ptype": "arg_select",
        "values": ["f16", "q8_0", "q4_0"],
        "default": "f16",
        "ui_group": "Core",
        "note": "IK-llama uses f16 by default for high precision with sm_120."
      },
      {
        "key": "Flash-Attn",
        "label": "Flash-Attn",
        "config_key": "flash_attn",
        "flag": "-fa",
        "ptype": "arg_select",
        "values": ["on", "off"],
        "default": "on",
        "ui_group": "Performance",
        "note": "Mandatory for Blackwell SM_120."
      }
    ]
  }
}
