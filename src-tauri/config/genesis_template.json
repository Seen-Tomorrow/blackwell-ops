{
  "version": 3,
  "ggml-stable": {
    "binary_name": "llama-server.exe",
    "description": "Official llama.cpp stable build",
    "params": [
      {
        "key": "KV-Quant",
        "label": "KV-Quant",
        "config_key": "kv_quant",
        "flag": "-ctk",
        "ptype": "arg_select",
        "values": ["q4_0", "q8_0", "f16"],
        "default": "q4_0",
        "ui_group": "Core",
        "note": "KV cache quantization. Also applied to -ctv automatically."
      },
      {
        "key": "CTX",
        "label": "CTX",
        "config_key": "ctx_size",
        "flag": "--ctx-size",
        "ptype": "mapper",
        "map_id": "CTX_TO_INT",
        "values": ["8K", "16K", "32K", "64K", "128K", "256K", "512K", "1M"],
        "default": "8K",
        "ui_group": "Core",
        "note": "Context window size. Transformed to integer tokens at runtime."
      },
      {
        "key": "Batch",
        "label": "Batch",
        "config_key": "batch",
        "flag": "--batch-size",
        "ptype": "arg_select",
        "values": [128, 256, 512, 1024, 2048, 4096, 8192],
        "default": 2048,
        "ui_group": "Performance",
        "note": "Batch size for token processing."
      },
      {
        "key": "uBatch",
        "label": "UBatch",
        "config_key": "ubatch",
        "flag": "--ubatch-size",
        "ptype": "arg_select",
        "values": [128, 256, 512, 1024, 2048, 4096, 8192],
        "default": 1024,
        "ui_group": "Performance",
        "note": "Micro-batch size for inference."
      },
      {
        "key": "Parallel",
        "label": "Parallel",
        "config_key": "parallel",
        "flag": "--parallel",
        "ptype": "arg_select",
        "values": [1, 2, 4, 8],
        "default": 1,
        "ui_group": "Performance",
        "note": "Number of concurrent request sequences."
      },
      {
        "key": "Unified-KV",
        "label": "Unified-KV",
        "config_key": "unified_kv",
        "flag": null,
        "ptype": "logic_only",
        "values": ["on", "off"],
        "default": "on",
        "ui_group": "Feature Flags",
        "note": "When off and Parallel > 1, each sequence gets its own KV cache (VRAM multiplied by np)."
      },
      {
        "key": "Offload",
        "label": "Offload",
        "config_key": "offload",
        "flag": "--n-gpu-layers",
        "ptype": "mapper",
        "map_id": "OFFLOAD_MAP",
        "values": ["all", "10", "15", "20", "25", "30", "35", "40", "45", "50"],
        "default": "all",
        "ui_group": "Multi-GPU",
        "note": "Number of layers to offload. 'ALL' maps to 999."
      },
      {
        "key": "Offload_Mode",
        "label": "Offload_Mode",
        "config_key": "offload_mode",
        "flag": null,
        "ptype": "logic_only",
        "values": ["regular", "moe_optimal"],
        "default": "regular",
        "ui_group": "Multi-GPU",
        "note": "moe_optimal adds expert eviction filter and forces KV quant to q4_0.",
        "sub_params": {
          "moe_optimal": ["-ot", "\\\\.ffn_.*_exps\\\\.=CPU", "-ctk", "q4_0", "-ctv", "q4_0"]
        }
      },
      {
        "key": "Device",
        "label": "Device",
        "config_key": "device",
        "flag": null,
        "ptype": "arg_select",
        "values": ["GPU-0", "GPU-1"],
        "default": "GPU-0",
        "ui_group": "Core",
        "note": "Select which GPU to use for inference."
      },
      {
        "key": "Split",
        "label": "Split",
        "config_key": "split_mode",
        "flag": "--split-mode",
        "ptype": "arg_select",
        "values": ["none", "layer", "row"],
        "default": "none",
        "ui_group": "Multi-GPU",
        "note": "How to split model across multiple GPUs."
      },
      {
        "key": "Vision",
        "label": "Vision",
        "config_key": "vision",
        "flag": "--mmproj",
        "ptype": "path_scanner",
        "values": ["auto", "off"],
        "default": "auto",
        "ui_group": "Feature Flags",
        "pattern": "*mmproj*",
        "note": "auto scans model directory for mmproj/projector files."
      },
      {
        "key": "Reasoning",
        "label": "Reasoning",
        "config_key": "reasoning",
        "flag": "--reasoning",
        "ptype": "arg_select",
        "values": ["on", "off"],
        "default": "off",
        "ui_group": "Feature Flags",
        "note": "Enable chain-of-thought reasoning output.",
        "sub_params": {
          "on": ["--reasoning-budget", "4096", "--reasoning-format", "deepseek"],
          "off": []
        }
      },
      {
        "key": "MMAP",
        "label": "MMAP",
        "config_key": "mmap",
        "flag": null,
        "ptype": "switch_inverted",
        "values": ["on", "off"],
        "default": "on",
        "ui_group": "Feature Flags",
        "note": "on = use mmap (no flag), OFF = --no-mmap. Inverted logic."
      },
      {
        "key": "Flash-Attn",
        "label": "Flash-Attn",
        "config_key": "flash_attn",
        "flag": "--flash-attn",
        "ptype": "arg_select",
        "values": ["on", "off"],
        "default": "on",
        "ui_group": "Performance",
        "note": "Enable Flash Attention 2."
      },
      {
        "key": "Jinja",
        "label": "Jinja",
        "config_key": "jinja",
        "flag": "--jinja",
        "ptype": "switch_onoff",
        "values": ["on", "off"],
        "default": "on",
        "ui_group": "Feature Flags",
        "note": "Enable Jinja templating for chat."
      },
      {
        "key": "Cont-Batching",
        "label": "Cont-Batching",
        "config_key": "cont_batching",
        "flag": "--cont-batching",
        "ptype": "switch_onoff",
        "values": ["on", "off"],
        "default": "on",
        "ui_group": "Feature Flags",
        "note": "Enable continuous batching."
      },
      {
        "key": "Metrics",
        "label": "Metrics",
        "config_key": "metrics",
        "flag": "--metrics",
        "ptype": "switch_onoff",
        "values": ["on"],
        "default": "on",
        "ui_group": "Feature Flags",
        "note": "Enable Prometheus-style metrics endpoint."
      },
      {
        "key": "Verbose",
        "label": "Verbose",
        "config_key": "verbose",
        "flag": "--verbose",
        "ptype": "switch_onoff",
        "values": ["on", "off"],
        "default": "off",
        "ui_group": "Feature Flags"
      },
      {
        "key": "log-timestamps",
        "label": "Log-Timestamps",
        "config_key": "log_timestamps",
        "flag": "--log-timestamps",
        "ptype": "switch_onoff",
        "values": ["on", "off"],
        "default": "on",
        "ui_group": "Feature Flags",
        "note": "Forces line flush per output - critical for real-time log streaming."
      }
    ]
  },
