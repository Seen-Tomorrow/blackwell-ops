{
  "productName": "Blackwell Ops",
  "version": "1.0.20",
  "identifier": "com.blackwell-ops.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Blackwell Ops",
        "width": 1400,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 768,
        "resizable": true,
        "transparent": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob:; font-src 'self' data: https://fonts.gstatic.com https://fonts.googleapis.com; connect-src 'self';"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "runtime-bundle/": "runtime/",
      "bin/": "bin/"
    },
    "icon": [
      "icons/icon-release.ico"
    ],
    "windows": {
      "minimumWebview2Version": "131.0.2903.0",
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "compression": "none",
        "template": "./nsis/installer.nsi",
        "languages": ["English"],
        "customLanguageFiles": {
          "English": "./nsis/languages/English.nsh"
        },
        "installerHooks": "./nsis-speedup.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk4NTg0OEM1M0Y1NDFGMjUKUldRbEgxUS94VWhZbVBhYnlDUzc1bmxyd3RPTitwQ1dtcEpxZlFzb3ZqOWQ4eVdDQW9TL3F1UkwK"
    }
  }

}
