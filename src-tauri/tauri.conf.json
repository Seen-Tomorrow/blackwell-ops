{
  "productName": "Blackwell Ops",
  "version": "0.7.7",
  "identifier": "com.blackwell-ops.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Blackwell Ops",
        "width": 1400,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 768,
        "resizable": true,
        "transparent": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:1420; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:1420; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob:; font-src 'self' data: https://fonts.gstatic.com https://fonts.googleapis.com; connect-src 'self' http://localhost:1420 ws://localhost:1420;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["runtime"],
    "icon": [
      "icons/icon-release.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk4NTg0OEM1M0Y1NDFGMjUKUldRbEgxUS94VWhZbVBhYnlDUzc1bmxyd3RPTitwQ1dtcEpxZlFzb3ZqOWQ4eVdDQW9TL3F1UkwK"
    },
    "nsis": {
      "compression": "none",
      "installerHooks": "nsis-speedup.nsh"
    }
  }

}
