LangString dontUninstallDowngrade ${LANG_ENGLISH} "Keep existing install$\nDowngrade requires uninstall first"
LangString failedToKillApp ${LANG_ENGLISH} "Failed to kill {{product_name}}. Please close it first then try again"
LangString installingWebview2 ${LANG_ENGLISH} "Installing WebView2..."
LangString newerVersionInstalled ${LANG_ENGLISH} "A newer version of ${PRODUCTNAME} is already installed. Downgrading without uninstall is disabled. Uninstall the current version first, or cancel and keep your existing install."
LangString older ${LANG_ENGLISH} "older"
LangString olderOrUnknownVersionInstalled ${LANG_ENGLISH} "An $R4 version of ${PRODUCTNAME} is installed. The installer will update in place and keep your foundry builds, config, and engines. On the next page you can change the folder to install into a new empty directory instead."
