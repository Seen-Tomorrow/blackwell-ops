# Tauri CLI file watcher (tauri dev) - gitignore-style rules.
# Watcher covers ALL of src-tauri (not just .rs). Ignore non-source trees.

# Entire runtime tree: factory JSON, plugin catalog, AND engine binaries
# (Pack Full runs mirror-artifacts -> copies .dll/.exe here every ship)
runtime/**

# NSIS staging (prepare-release-runtime)
runtime-bundle/**

# Cargo build outputs (usually already skipped; belt-and-suspenders)
target/**

# DISTRIBUTION bump rewrites these; must not kill pack mid-chain
Cargo.toml
Cargo.lock
tauri.conf.json
tauri.conf.dev.json
