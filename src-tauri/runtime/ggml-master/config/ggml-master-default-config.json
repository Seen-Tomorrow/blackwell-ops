{
  "id": "ggml-master",
  "display_name": "GGML Master",
  "binary_name": "llama-server.exe",
  "description": "Official llama.cpp master build",
  "git_url": "https://github.com/ggml-org/llama.cpp",
  "branch": "master",
  "template_type": "ggml-llama",
  "templateVersion": 11,
  "build_profile": "-DGGML_CUDA=ON\n-DCMAKE_CUDA_ARCHITECTURES=\"86;89;120\"\n-DGGML_CUDA_PEER_TO_PEER=ON\n-DGGML_CUDA_FA_ALL_QUANTS=ON\n-DGGML_AVX512=ON\n-DGGML_NATIVE=ON\n-DCMAKE_CUDA_FLAGS=\"-Xcompiler /wd4056 -Xcompiler /wd4756 --diag-suppress 221\"\n-Wno-dev",
  "spawn_profile": {
    "model_flag": ["-m"],
    "port_flag": ["--port"],
    "alias_flag": ["--alias"],
    "verbosity_args": ["-lv", "4"],
    "auto_vram": true,
    "fit_style": "ggml_fit_params",
    "simple_param_keys": ["device", "ctx", "kv_quant", "parallel", "mmap"],
    "enable_metrics": true,
    "supports_fusion": true,
    "max_engine_slots": 64,
    "gpu_env": "CUDA_VISIBLE_DEVICES",
    "ngl_flag": ["--n-gpu-layers"],
    "mmproj_flag": ["--mmproj"]
  },
  "params": [
    {
      "key": "device",
      "label": "DEVICE",
      "flag": null,
      "ptype": "logic_only",
      "values": ["GPU-0", "GPU-1"],
      "default": "GPU-0",
      "dock": "runtime",
      "ui_group": "MULTI-GPU",
      "note": "Select GPU via CUDA_VISIBLE_DEVICES mask — not emitted as a CLI flag."
    },
    {
      "key": "offload_mode",
      "label": "OFFLOAD-MODE",
      "flag": null,
      "ptype": "logic_only",
      "values": ["regular", "moe_optimal"],
      "default": "regular",
      "dock": "runtime",
      "ui_group": "MULTI-GPU",
      "note": "moe_optimal adds expert eviction filter and forces KV quant to q4_0.",
      "sub_params": {
        "moe_optimal": ["-ot", "\\\\.ffn_.*_exps\\\\.=CPU", "-ctk", "q4_0", "-ctv", "q4_0"]
      }
    },
    {
      "key": "split",
      "label": "SPLIT",
      "flag": "--split-mode",
      "ptype": "arg_select",
      "values": ["none", "layer", "row", "tensor"],
      "default": "none",
      "dock": "runtime",
      "ui_group": "MULTI-GPU",
      "note": "How to split model across multiple GPUs."
    },
    {
      "key": "base_port",
      "label": "BASE-PORT",
      "flag": null,
      "ptype": "logic_only",
      "values": [8080, 8180, 8888, 9090],
      "default": 8080,
      "dock": "runtime",
      "ui_group": "RUNTIME-CONFIG",
      "note": "Starting port for engine instances. Auto-increments per slot."
    },
    {
      "key": "kv_quant",
      "label": "KV-QUANT (K+V)",
      "ptype": "arg_select_double",
      "flag_pair": ["--cache-type-k", "--cache-type-v"],
      "values": ["q4_0", "q8_0", "f16"],
      "default": "q4_0",
      "ui_group": "CORE",
      "note": "KV cache data type for both K and V cache, set together."
    },
    {
      "key": "ctx",
      "label": "CTX",
      "flag": "--ctx-size",
      "ptype": "slider",
      "step": 1024,
      "default": 32768,
      "values": [8192, 16384, 32768, 65536, 131072, 262144, 524288],
      "ui_group": "CORE",
      "note": "Context window size in tokens."
    },
    {
      "key": "batch",
      "label": "BATCH",
      "flag": "--batch-size",
      "ptype": "arg_select",
      "values": [128, 256, 512, 1024, 2048, 4096, 8192],
      "default": 4096,
      "ui_group": "PERFORMANCE",
      "note": "Batch size for token processing."
    },
    {
      "key": "ubatch",
      "label": "UBATCH",
      "flag": "--ubatch-size",
      "ptype": "arg_select",
      "values": [32, 64, 128, 256, 512, 1024, 2048],
      "default": 512,
      "ui_group": "PERFORMANCE",
      "note": "Micro-batch size for inference."
    },
    {
      "key": "parallel",
      "label": "PARALLEL",
      "flag": "--parallel",
      "ptype": "arg_select",
      "values": [1, 2, 4, 8, 16, 32],
      "default": 1,
      "ui_group": "PERFORMANCE",
      "note": "Number of concurrent request sequences."
    },
    {
      "key": "unified_kv",
      "label": "UNIFIED-KV",
      "flag": "--no-kv-unified",
      "ptype": "switch_inverted",
      "values": ["on", "off"],
      "default": "on",
      "ui_group": "PERFORMANCE",
      "note": "When off and Parallel > 1, each sequence gets its own KV cache (VRAM multiplied by np)."
    },
    {
      "key": "flash_attn",
      "label": "FLASH-ATTN",
      "flag": "--flash-attn",
      "ptype": "arg_select",
      "values": ["on", "off", "auto"],
      "default": "on",
      "ui_group": "PERFORMANCE",
      "note": "Enable Flash Attention 2."
    },
    {
      "key": "vision",
      "label": "VISION",
      "flag": "--mmproj",
      "ptype": "path_scanner",
      "values": ["auto", "off"],
      "default": "auto",
      "ui_group": "FEATURE-FLAGS",
      "pattern": "*mmproj*",
      "note": "auto scans model directory for mmproj/projector files."
    },
    {
      "key": "reasoning",
      "label": "REASONING",
      "flag": "--reasoning",
      "ptype": "arg_select",
      "values": ["on", "off"],
      "default": "off",
      "ui_group": "FEATURE-FLAGS",
      "note": "Enable chain-of-thought reasoning output.",
      "sub_params": {
        "on": ["--reasoning-budget", "4096", "--reasoning-format", "deepseek"],
        "off": []
      }
    },
    {
      "key": "mmap",
      "label": "MMAP",
      "flag": "--no-mmap",
      "ptype": "switch_inverted",
      "values": ["on", "off"],
      "default": "off",
      "ui_group": "FEATURE-FLAGS",
      "note": "on = use mmap (no flag), off = --no-mmap. Inverted logic."
    },
    {
      "key": "jinja",
      "label": "JINJA",
      "flag": "--jinja",
      "ptype": "switch_onoff",
      "values": ["on", "off"],
      "default": "on",
      "ui_group": "FEATURE-FLAGS",
      "note": "Enable Jinja templating for chat."
    },
    {
      "key": "cont_batching",
      "label": "CONT-BATCHING",
      "flag": "--cont-batching",
      "ptype": "switch_onoff",
      "values": ["on", "off"],
      "default": "on",
      "ui_group": "FEATURE-FLAGS",
      "note": "Enable continuous batching."
    },
    {
      "key": "spec_type",
      "label": "SPEC-TYPE",
      "flag": "--spec-type",
      "ptype": "arg_select",
      "values": ["none", "draft-simple", "draft-eagle3", "draft-mtp", "ngram-simple", "ngram-map-k", "ngram-map-k4v", "ngram-mod", "ngram-cache"],
      "default": "draft-mtp",
      "ui_group": "SPECULATIVE-DECODING",
      "hidden_default": true,
      "note": "Comma-separated speculative decoding types. 'none' disables."
    },
    {
      "key": "spec_draft_n_max",
      "label": "SPEC-DRAFT-N-MAX",
      "flag": "--spec-draft-n-max",
      "ptype": "arg_select",
      "values": [1, 2, 3, 4, 5, 6, 8, 10, 16],
      "default": 3,
      "ui_group": "SPECULATIVE-DECODING",
      "hidden_default": true,
      "note": "Maximum number of draft tokens per speculative decoding step."
    },
	    {
      "key": "spec_draft_n_min",
      "label": "SPEC-DRAFT-N-MIN",
      "flag": "--spec-draft-n-min",
      "ptype": "arg_select",
      "values": [1, 2, 3, 4, 5],
      "default": 1,
      "ui_group": "SPECULATIVE-DECODING",
      "hidden_default": true,
      "note": "minimum number of draft tokens to use for speculative decoding."
    }
  ]
}