# Ignore the actual server executable if you download it externally
# but keep your integration logic.
*.exe
*.dll
*.pdb
*.d
llama-server.exe

# IMPORTANT: Ignore large Model files (GGUF, etc) 
# You do NOT want to push 4GB-70GB models to GitHub
*.gguf
*.bin
models/

# --- Foundry portable toolchain (manifest.json is committed; blobs are local) ---
toolchain/VC/
toolchain/Windows Kits/
toolchain/cuda/
toolchain/vs/

# --- Build Counter (local, auto-incrementing) ---
.build_counter.json

# --- Tauri Updater Signing Key (NEVER commit!) ---
src-tauri/updater_private.key

# --- Majestic release robot (local only) ---
.majestic-out/
.majestic-backup/

