{
  "name": "blackwell-ops",
  "private": true,
  "version": "1.0.17",
  "type": "module",
  "scripts": {
    "vite": "vite --host 127.0.0.1 --port 1420",
    "server": "node scripts/warm-vite-dev.mjs",
    "predev": "powershell -ExecutionPolicy Bypass -File scripts/sync-dev-runtime.ps1",
    "dev": "tauri dev --config src-tauri/tauri.conf.dev.json",
    "build": "tsc && vite build",
    "build:frontend": "tsc && vite build",
    "build:exe": "npm run build && tauri build --no-bundle",
    "build:rust": "cargo build --release --manifest-path src-tauri/Cargo.toml",
    "rebuild:frontend": "powershell -ExecutionPolicy Bypass -File scripts/rebuild-frontend.ps1",
    "rebuild:dev": "powershell -ExecutionPolicy Bypass -File scripts/rebuild-dev.ps1",
    "rebuild:dev:selective": "powershell -ExecutionPolicy Bypass -File scripts/rebuild-dev-selective.ps1",
    "preview": "vite preview",
    "prerelease": "powershell -ExecutionPolicy Bypass -File scripts/mirror-artifacts.ps1 && powershell -ExecutionPolicy Bypass -File scripts/prepare-release-runtime.ps1",
    "release": "npm run build && tauri build",
    "release:exe": "npm run build:exe",
    "majestic:check": "powershell -ExecutionPolicy Bypass -File scripts/majestic/majestic.ps1 -Mode check -Variant full",
    "majestic:check:app": "powershell -ExecutionPolicy Bypass -File scripts/majestic/majestic.ps1 -Mode check -Variant app",
    "majestic:bump": "powershell -ExecutionPolicy Bypass -File scripts/majestic/majestic.ps1 -Mode bump",
    "majestic:pack": "powershell -ExecutionPolicy Bypass -File scripts/majestic/majestic.ps1 -Mode pack -Variant full",
    "majestic:pack:app": "powershell -ExecutionPolicy Bypass -File scripts/majestic/majestic.ps1 -Mode pack -Variant app",
    "majestic:ship": "powershell -ExecutionPolicy Bypass -File scripts/majestic/majestic.ps1 -Mode ship",
    "majestic:ship:app": "powershell -ExecutionPolicy Bypass -File scripts/majestic/majestic.ps1 -Mode ship",
    "majestic:toolchain": "powershell -ExecutionPolicy Bypass -File scripts/build-foundry-toolchain.ps1",
    "majestic:ship-toolchain": "powershell -ExecutionPolicy Bypass -File scripts/majestic/majestic.ps1 -Mode ship-toolchain",
    "majestic:pack:provider": "powershell -ExecutionPolicy Bypass -File scripts/majestic/majestic.ps1 -Mode pack-provider",
    "majestic:ship:provider": "powershell -ExecutionPolicy Bypass -File scripts/majestic/majestic.ps1 -Mode ship-provider",
    "promote:provider": "node scripts/promote-user-provider-to-runtime.mjs",
    "pack:provider": "powershell -ExecutionPolicy Bypass -File scripts/pack-provider-runtime.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-shell": "^2",
    "ansi-to-html": "^0.7.2",
    "html-to-image": "^1.11.13",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "~5.6.0",
    "vite": "^8.0.16"
  }
}
