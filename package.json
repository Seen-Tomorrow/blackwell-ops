{
  "name": "blackwell-ops",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "server": "vite --port 1420",
    "predev": "powershell -Command \"if (Test-Path src-tauri/runtime) { New-Item -ItemType Directory -Path target/debug/runtime -Force | Out-Null; Copy-Item -Path 'src-tauri/runtime/*' -Destination target/debug/runtime/ -Recurse -Force }\"",
    "dev": "tauri dev --config src-tauri/tauri.conf.dev.json",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "release": "npm run build && tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-shell": "^2",
    "ansi-to-html": "^0.7.2",
    "framer-motion": "^12.39.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "~5.6.0",
    "vite": "^8.0.13"
  }
}
