{
  "name": "blackwell-ops",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "scripts": {
    "server": "vite --port 1420",
    "predev": "powershell -Command \"if (Test-Path src-tauri/runtime) { New-Item -ItemType Directory -Path target/debug/runtime -Force | Out-Null; Copy-Item -Path 'src-tauri/runtime/*' -Destination target/debug/runtime/ -Recurse -Force }\"",
    "dev": "tauri dev --config src-tauri/tauri.conf.dev.json",
    "build": "tsc && vite build",
    "build:frontend": "tsc && vite build",
    "rebuild:frontend": "powershell -ExecutionPolicy Bypass -File scripts/rebuild-frontend.ps1",
    "rebuild:dev": "powershell -ExecutionPolicy Bypass -File scripts/rebuild-dev.ps1",
    "rebuild:dev:selective": "powershell -ExecutionPolicy Bypass -File scripts/rebuild-dev-selective.ps1",
    "preview": "vite preview",
    "prerelease": "powershell -ExecutionPolicy Bypass -File scripts/mirror-artifacts.ps1 && powershell -ExecutionPolicy Bypass -File scripts/prepare-release-runtime.ps1",
    "release": "npm run build && tauri build",
    "majestic:check": "powershell -ExecutionPolicy Bypass -File scripts/majestic/majestic.ps1 -Mode check",
    "majestic:bump": "powershell -ExecutionPolicy Bypass -File scripts/majestic/majestic.ps1 -Mode bump",
    "majestic:pack": "powershell -ExecutionPolicy Bypass -File scripts/majestic/majestic.ps1 -Mode pack",
    "majestic:ship": "powershell -ExecutionPolicy Bypass -File scripts/majestic/majestic.ps1 -Mode ship"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-shell": "^2",
    "ansi-to-html": "^0.7.2",
    "html-to-image": "^1.11.13",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "~5.6.0",
    "vite": "^8.0.13"
  }
}
